# ===========================================
# SmartGuard 反诈智能助手 - 环境配置示例
# ===========================================
# 复制此文件为 .env 并填入实际值

# ========== LLM 配置 (通义千问) ==========
# 访问 https://dashscope.console.aliyun.com 获取 API Key
DASHSCOPE_API_KEY=your_api_key_here

# LLM 模型选择
# qwen-turbo: 快速版，适合简单任务
# qwen-plus: 增强版，性能更强
# qwen-max: 最高性能版
QWEN_MODEL=qwen-turbo

# LLM 参数
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=2000

# 是否启用联网搜索
QWEN_ENABLE_SEARCH=false


# ========== 数据库配置 ==========
DATABASE_URL=sqlite:///./data/smartguard.db


# ========== Redis 配置 (可选) ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


# ========== API 配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false


# ========== 安全配置 ==========
# API 密钥 (用于认证)
API_KEY=your_secret_key_here

# JWT 密钥
JWT_SECRET=your_jwt_secret_here


# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=logs/smartguard.log
